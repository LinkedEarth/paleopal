          ],
          "keywords": [
            "time series",
            "intervals",
            "overlap"
          ]
        },
        {
          "step_number": 5,
          "category": "data_processing",
          "description": "For each time interval, identify dates from the calibrated cultural dataset that fall within the interval or within ±400 years of the interval boundaries.",
          "searchable_summary": "select dates within time interval and smoothing window",
          "inputs": [
