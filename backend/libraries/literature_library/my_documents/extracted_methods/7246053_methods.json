            "temporal smoothing"
          ]
        },
        {
          "step_number": 6,
          "category": "data_processing",
          "description": "Assign a weight (w) to each selected date: w=1 for dates within the interval, and w < 1 for dates within ±400 years. The weight for dates outside the interval is calculated as 1 - (temporal distance to the nearest interval boundary / 400).",
          "searchable_summary": "assign temporal weights to dates",
          "inputs": [
            "Subset of dates for current interval",
            "Current time interval boundaries"
          ],
          "outputs": [
            "Subset of dates with assigned weights"
          ],
          "keywords": [
            "weighting",
            "temporal distance",
            "smoothing"
          ]
        },
        {
          "step_number": 7,
          "category": "data_processing",
          "description": "If multiple dates exist for a single site within an interval (including the ±400y window with weights), consider each date separately in the subsequent density estimation.",
          "searchable_summary": "handle multiple dates per site",
          "inputs": [
            "Subset of dates with assigned weights"
          ],
          "outputs": [
            "Weighted dates dataset (ready for KDE)"
          ],
          "keywords": [
            "multiple dates",
            "site",
            "data handling"
          ]
        },
        {
          "step_number": 8,
          "category": "data_analysis",
          "description": "Apply Kernel Density Estimation (KDE) to the weighted dates dataset for the current time interval to produce raw population estimates.",
          "searchable_summary": "perform weighted kernel density estimation",
          "inputs": [
            "Weighted dates dataset (ready for KDE)",
            "Analysis grid (land areas only)"
          ],
          "outputs": [
            "Raw population estimate map (current interval)"
          ],
          "keywords": [
            "kernel density estimation",
            "weighted KDE",
            "spatial analysis",
            "population estimation"
          ]
        },
        {
          "step_number": 9,
          "category": "data_processing",
