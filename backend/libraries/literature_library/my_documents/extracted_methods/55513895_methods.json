            "glutaraldehyde",
            "fixation",
            "buffer"
          ]
        },
        {
          "step_number": 2,
          "category": "data_processing",
          "description": "Washed (6 times) in 0.05 M phosphate buffer (pH 7.2; 1.5 hrs total).",
          "searchable_summary": "Wash fixed anthers in phosphate buffer",
          "inputs": [
            "fixed anthers",
            "phosphate buffer"
          ],
          "outputs": [
            "washed anthers"
          ],
