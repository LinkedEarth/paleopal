            "postfixation"
          ]
        },
        {
          "step_number": 4,
          "category": "data_processing",
          "description": "Post-stained with 2% aqueous uranyl acetate followed by Reynolds' lead citrate.",
          "searchable_summary": "Stain anthers with uranyl acetate and lead citrate",
          "inputs": [
            "postfixed anthers",
