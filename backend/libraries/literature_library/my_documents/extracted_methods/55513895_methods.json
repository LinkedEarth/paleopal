      "method_name": "Pollen Preparation for Scanning Electron Microscopy (SEM)",
      "description": "This method describes the preparation of pollen samples for SEM analysis, which is used to examine the three-dimensional structure of pollen grains. The method is quicker and less hazardous than conventional acetolysis and preserves the pollen's structure.",
      "steps": [
        {
          "step_number": 1,
          "category": "data_processing",
          "description": "Anthers were crushed in a c. 5 cc volume of 50% acetone, suspended using a whirli-mix and centrifuged (2,500 rpm for 8 minutes).",
          "searchable_summary": "Crush anthers and centrifuge in 50% acetone",
          "inputs": [
            "anthers",
            "50% acetone"
          ],
          "outputs": [
            "centrifuged pellet"
          ],
          "keywords": [
            "anthers",
            "centrifuge",
            "acetone"
          ]
        },
        {
          "step_number": 2,
          "category": "data_processing",
          "description": "The pellet (largely pollen) was then repeatedly dehydrated by re-suspension in increasing acetone concentrations (75-100%).",
          "searchable_summary": "Dehydrate pollen pellet with increasing acetone concentrations",
          "inputs": [
            "centrifuged pellet",
            "acetone"
          ],
          "outputs": [
            "dehydrated pollen pellet"
          ],
          "keywords": [
            "dehydration",
            "acetone"
          ]
        },
        {
          "step_number": 3,
          "category": "data_processing",
          "description": "The penultimate re-suspended pellet was sieved (90 µm) and the final pellet dropped onto a SEM stub and allowed to dry overnight in a dessicator.",
          "searchable_summary": "Sieve and dry pollen pellet on SEM stub",
          "inputs": [
            "dehydrated pollen pellet"
          ],
          "outputs": [
            "dried pollen on SEM stub"
          ],
          "keywords": [
            "sieve",
            "SEM stub",
            "dessicator"
          ]
        },
        {
          "step_number": 4,
          "category": "data_processing",
          "description": "The stubs were gold-coated in a Polaron SC500 sputter coater for viewing in a Leica-Cambridge Stereoscan 360, Hitachi S4300 or Hitachi S3500n.",
          "searchable_summary": "Gold-coat SEM stubs for microscopy",
          "inputs": [
            "dried pollen on SEM stub"
          ],
          "outputs": [
            "gold-coated SEM stub"
          ],
          "keywords": [
            "gold-coating",
            "sputter coater",
            "SEM"
          ]
        }
      ]
    },
    {
      "method_name": "Pollen Preparation for Transmission Electron Microscopy (TEM)",
      "description": "This method outlines the preparation of pollen samples for TEM analysis, which provides detailed internal structural information of pollen grains.",
      "steps": [
        {
          "step_number": 1,
          "category": "data_processing",
          "description": "Air-dried anthers were fixed in glutaraldehyde (3%) in 0.05 M potassium phosphate buffer (1 hr).",
